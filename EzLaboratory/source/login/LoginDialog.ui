  <property name="styleSheet">
   <string notr="true">QDialog#LoginDialog {
    background: transparent;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Segoe UI&quot;;
}

QLineEdit {
    padding-left: 10px;
    border: none;
    font-size: 15px;
    background: #FFFFFF;
}

QPushButton#loginButton,
QPushButton#registerButton,
QPushButton#VcCodeButton {
    background-color: rgb(0, 170, 255);
    border: none;
    color: rgb(255, 255, 255);
}

QPushButton#loginButton,
QPushButton#registerButton {
    font-size: 20px;
}

QPushButton#VcCodeButton {
    font-size: 15px;
}

QPushButton#loginButton:pressed,
QPushButton#registerButton:pressed,
QPushButton#VcCodeButton:pressed {
    background-color: rgb(0, 85, 255);
    color: rgb(255, 255, 255);
}

QPushButton#registerCut,
QPushButton#loginCut,
QPushButton#pushButton_3,
QPushButton#pushButton_4,
QCheckBox {
    border: none;
    color: rgb(0, 170, 255);
    background: transparent;
}

QPushButton#registerCut:hover,
QPushButton#loginCut:hover,
QPushButton#pushButton_3:hover,
QPushButton#pushButton_4:hover,
QCheckBox:hover {
    text-decoration: underline;
}

QPushButton#MinusButton,
QPushButton#CloseButton {
    border: none;
    background: transparent;
}

QPushButton#MinusButton:hover,
QPushButton#CloseButton:hover {
    background-color: #A80000;
    color: white;
}

QLabel#registerWarring {
    color: #D03030;
    font-size: 12px;
}</string>
