  <property name="styleSheet">
   <string notr="true">* {
    border: 0;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Segoe UI&quot;;
}

QMainWindow,
QWidget#centralWidget,
QWidget#mainContentWidget {
    background: #FFFFFF;
}

QWidget#topBar {
    background: #FFFFFF;
    border-bottom: 1px solid #D6D6D6;
}

QLabel#brandLabel {
    color: #3D3D3D;
    font-weight: 600;
}

QWidget#searchFrame {
    background: #EEEEEE;
    border-radius: 8px;
}

QLabel#searchIconLabel {
    background: transparent;
}

QLineEdit#searchLineEdit {
    background: transparent;
    color: #3D3D3D;
    font-size: 14px;
    padding: 0px 2px;
}

QWidget#sideBar {
    background: #F1F1F1;
    border-right: 1px solid #D6D6D6;
}

QToolButton {
    background: transparent;
    border-radius: 4px;
    color: #8C8C8C;
}

QToolButton:hover {
    background: #E7E7E7;
}

QToolButton:pressed {
    background: #DADADA;
}

QToolButton#closeButton:hover {
    background: #E81123;
}

QToolButton#navExperimentsButton {
    color: #8C8C8C;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
}

QToolButton#navExperimentsButton:hover,
QToolButton#historyButton:hover,
QToolButton#themeButton:hover,
QToolButton#settingsButton:hover {
    background: #E6E6E6;
}

QToolButton#avatarButton {
    background: #D8D8D8;
    border-radius: 24px;
}

QToolButton#avatarButton:hover {
    background: #CCCCCC;
}

QWidget#avatarWidget[selected="true"] {
    background: #E6E6E6;
}

QToolButton#navExperimentsButton:checked,
QToolButton#historyButton:checked,
QToolButton#settingsButton:checked {
    background: #E6E6E6;
    color: #F97316;
}

QScrollArea#experimentScrollArea {
    background: #FFFFFF;
    border: none;
}

QWidget#scrollContentWidget,
QWidget#experimentCardGridWidget {
    background: #FFFFFF;
}</string>
