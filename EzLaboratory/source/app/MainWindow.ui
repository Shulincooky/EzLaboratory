    font-size: 24px;
    font-weight: 700;
}

QLabel#subtitleLabel {
    color: #6B7280;
    font-size: 13px;
}

QLabel#connectionStatusLabel {
    color: #4B5563;
    background: #EEF2F7;
    border-radius: 12px;
    padding: 6px 12px;
}

QPushButton {
    background: #FFFFFF;
    border: 1px solid #D7DCE5;
    border-radius: 8px;
    color: #243047;
    padding: 8px 14px;
}

QPushButton:hover {
    background: #F1F4F8;
}

QPushButton#refreshButton {
    background: #6D5DF2;
    border: 1px solid #6D5DF2;
    color: #FFFFFF;
}

QPushButton#refreshButton:hover {
    background: #5A4BDD;
}

QScrollArea#experimentScrollArea {
    background: transparent;
    border: none;
}

QWidget#scrollContentWidget {
    background: transparent;
}

QWidget#cardGridWidget {
    background: transparent;
}

QFrame#emptyHintFrame {
    background: #FFFFFF;
    border: 1px dashed #CAD1DC;
    border-radius: 8px;
}

QLabel#emptyHintTitleLabel {
    color: #1F2937;
    font-size: 18px;
    font-weight: 700;
}

QLabel#emptyHintBodyLabel {
    color: #6B7280;
    font-size: 13px;
}</string>
