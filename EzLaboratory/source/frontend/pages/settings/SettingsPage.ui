  <property name="styleSheet">
   <string notr="true">QWidget#SettingsPage {
    background: #FFFFFF;
}

QScrollArea#settingsScrollArea,
QWidget#settingsCanvas,
QWidget[role=&quot;section&quot;],
QWidget#profileContainer,
QWidget#profileInfoContainer,
QWidget#aboutActionsContainer {
    background: #FFFFFF;
    border: none;
}

QLabel#avatarLabel {
    background: #D8D8D8;
    border-radius: 37px;
}

QLabel#adminNameLabel {
    color: #3D3D3D;
    font-size: 18px;
    font-weight: 700;
    min-height: 18px;
}

QLabel[role=&quot;sectionTitle&quot;] {
    color: #3D3D3D;
    font-size: 16px;
    font-weight: 700;
    min-height: 24px;
}

QLabel[role=&quot;optionLabel&quot;],
QLabel#versionLabel {
    color: #3D3D3D;
    font-size: 14px;
    font-weight: 600;
    min-height: 22px;
}

QComboBox,
QLineEdit {
    background: #FFFFFF;
    border: 1px solid #DADADA;
    border-radius: 4px;
    color: #3D3D3D;
    font-size: 13px;
    min-height: 26px;
    padding: 1px 8px;
}

QComboBox:hover,
QLineEdit:hover {
    border-color: #F97316;
}

QCheckBox {
    color: #3D3D3D;
    font-size: 14px;
    font-weight: 600;
    min-height: 22px;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 13px;
    height: 13px;
    border: 1px solid #B8B8B8;
    background: #FFFFFF;
}

QCheckBox::indicator:checked {
    background: #F97316;
    border-color: #F97316;
}

QPushButton[role=&quot;textAction&quot;] {
    background: transparent;
    border: none;
    color: #F97316;
    font-size: 14px;
    font-weight: 600;
    min-height: 17px;
    padding: 0;
    text-align: left;
}

QPushButton[role=&quot;textAction&quot;]:hover {
    color: #EA580C;
}

QPushButton#clearHistoryButton,
QPushButton#testConnectionButton {
    color: #EF4444;
}</string>
